{
  "version": 8,
  "name": "Brussels Pedestrian Network",
  "metadata": {
    "maputnik:renderer": "mlgljs"
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "sources": {
    "ne2_shaded": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": ["https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"],
      "type": "raster"
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    },
    "pedestrian": {
      "type": "vector",
      "url": "pmtiles://https://VOTRE_NOM_UTILISATEUR.github.io/VOTRE_REPO/pedestrian.pmtiles.gz",
      "attribution": "© <a href='https://www.openstreetmap.org/copyright'>OpenStreetMap contributors</a>"
    }
  },
  "layers": [
    { "id": "background", "type": "background", "paint": { "background-color": "#1a1a1a" } },
    {
      "id": "natural_earth",
      "type": "raster",
      "source": "ne2_shaded",
      "maxzoom": 7,
      "paint": { "raster-opacity": 0.2 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#242d24", "fill-opacity": 0.7 }
    },
    {
      "id": "road_secondary_tertiary_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "class"], ["secondary", "tertiary"], true, false]],
      "paint": {
        "line-color": "#111111",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 8, 1.5, 20, 17]
      }
    },
    {
      "id": "road_secondary_tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "class"], ["secondary", "tertiary"], true, false]],
      "paint": {
        "line-color": "#2a2a2a",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 8, 0.5, 20, 13]
      }
    },
    {
      "id": "road_trunk_primary_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "class"], ["primary", "trunk"], true, false]],
      "paint": {
        "line-color": "#111111",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.4, 20, 22]
      }
    },
    {
      "id": "road_trunk_primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "class"], ["primary", "trunk"], true, false]],
      "paint": {
        "line-color": "#2a2a2a",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0, 20, 18]
      }
    },

    {
      "id": "road_motorway_link_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["match", ["get", "class"], ["motorway_link"], true, false]
      ],
      "paint": {
        "line-color": "#aaaaaa",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.6, 20, 20]
      }
    },
    {
      "id": "road_motorway_link",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["match", ["get", "class"], ["motorway_link"], true, false]
      ],
      "paint": {
        "line-color": "#d5d5d5",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0, 20, 16]
      }
    },

    {
      "id": "highway-living_street",
      "type": "line",
      "source": "pedestrian",
      "source-layer": "highways",
      "filter": ["==", ["get", "highway"], "living_street"],
      "layout": { "visibility": "none" },
      "paint": { "line-color": "#16a34a", "line-width": 2 }
    },
    {
      "id": "highway-pedestrian",
      "type": "line",
      "source": "pedestrian",
      "source-layer": "highways",
      "filter": ["==", ["get", "highway"], "pedestrian"],
      "layout": { "visibility": "none" },
      "paint": { "line-color": "#15803d", "line-width": 2 }
    },
    {
      "id": "highway-footway",
      "type": "line",
      "source": "pedestrian",
      "source-layer": "highways",
      "filter": ["==", ["get", "highway"], "footway"],
      "layout": { "visibility": "none" },
      "paint": { "line-color": "#22c55e", "line-width": 1.5 }
    },
    {
      "id": "forced-segments",
      "type": "line",
      "source": "pedestrian",
      "source-layer": "forced_segments",
      "layout": { "line-cap": "round", "line-join": "round", "visibility": "visible" },
      "paint": {
        "line-color": ["match", ["get", "highway"], ["residential", "service"], "#f59e0b", ["tertiary"], "#ef4444", "#dc2626"],
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 2, 16, 6]
      }
    },
    {
      "id": "forced-cycleway",
      "type": "line",
      "source": "pedestrian",
      "source-layer": "forced_cycleway",
      "layout": { "visibility": "visible" },
      "paint": { "line-color": "#7c3aed", "line-width": 3 }
    },
    {
      "id": "flow-ped",
      "type": "line",
      "source": "pedestrian",
      "source-layer": "flow_edges",
      "filter": ["==", ["get", "surface_cat"], "pedestrian"],
      "layout": { "visibility": "none" },
      "paint": { "line-color": "#16a34a", "line-width": 2 }
    },
    {
      "id": "flow-road",
      "type": "line",
      "source": "pedestrian",
      "source-layer": "flow_edges",
      "filter": ["==", ["get", "surface_cat"], "road"],
      "layout": { "visibility": "visible" },
      "paint": { "line-color": "#ef4444", "line-width": 4 }
    }
  ]
}
